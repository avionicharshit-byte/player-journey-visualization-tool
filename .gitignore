# IDE and editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Claude
.claude/

# Node modules (will be installed by Vercel)
node_modules/

# Build output (Vercel builds this)
dist/

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Raw parquet data files (large, not needed - we use processed JSON).
# This pattern catches any month-named folder under public/data/.
visualization-tool/public/data/January_*/
visualization-tool/public/data/February_*/
visualization-tool/public/data/March_*/
visualization-tool/public/data/April_*/
visualization-tool/public/data/May_*/
visualization-tool/public/data/June_*/
visualization-tool/public/data/July_*/
visualization-tool/public/data/August_*/
visualization-tool/public/data/September_*/
visualization-tool/public/data/October_*/
visualization-tool/public/data/November_*/
visualization-tool/public/data/December_*/

# Keep processed JSON files:
# - visualization-tool/public/data/matches.json
# - visualization-tool/public/data/stats.json
# - visualization-tool/public/data/matches/*.json
# - visualization-tool/public/minimaps/

# Preprocessing scripts output cache
*.pyc
__pycache__/

# Temp files
*.tmp
*.temp
